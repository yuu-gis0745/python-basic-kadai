      "source": [
        "# 第一引数に商品の金額、第二引数に消費税を設定する\n",
        "def tax_included(product_price: int, product_tax: float):\n",
        "\n",
        "# 消費税を加えた計算結果を返す関数\n",
        "    total = product_price + product_price * product_tax\n",
        "    return print(f\"消費税を加えた計算結果は{total}円です\")\n",
        "\n",
        "# 関数を呼び出して、商品の金額と消費税（10%）を設定する\n",
        "tax_included(110, 0.01)"
      ]
    }
  ]
