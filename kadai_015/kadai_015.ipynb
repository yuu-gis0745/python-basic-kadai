      "source": [
        "# Humanクラス\n",
        "class Human:\n",
        "    def __init__(self, name, age):\n",
        "        # 属性を定義\n",
        "        self.name = name\n",
        "        self.age = age\n",
        "# インスタンス化（nameとageを標準出力するためのメソッド(printinfo)）\n",
        "printinfo = Human(\"侍太郎\", 43)\n",
        "# 属性にアクセスし、値を出力する\n",
        "print(printinfo.name)\n",
        "print(printinfo.age)"
      ]
    }
  ]
