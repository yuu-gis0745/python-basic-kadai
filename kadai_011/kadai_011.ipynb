      "source": [
        "array = [\"水\",\"金\",\"地\",\"火\",\"木\",\"土\",\"天\",\"海\",\"冥\"]\n",
        "\n",
        "#arrayからp(ループ変数)に文字を格納\n",
        "for p in array:\n",
        "    print(p)\n",
        "\n",
        "#カウンタ変数iに0を格納\n",
        "i = 0\n",
        "\n",
        "#カウンタ変数に0を格納することで、1番目の要素を取り出す\n",
        "print(array[i])\n",
        "\n",
        "while array[i] != \"冥\":\n",
        "    i = i + 1\n",
        "    print(array[i])"
      ],
